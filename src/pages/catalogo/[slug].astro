---
import PostLayout from '@/layouts/PostLayout.astro';
import { Picture } from 'astro:assets';
import { ProductSchema } from '@/types';
import PostMeta from '@/components/products/PostMeta.astro';
import PostCategories from '@/components/products/PostCategories.astro';

export const prerender = false;

const { slug } = Astro.params;
console.log(slug);
const res = await fetch(`${import.meta.env.API_URL}/products?slug=${slug}`);
const json = await res.json();
console.log(json);
const post = ProductSchema.safeParse(json[0]);
if (!post.success) return Astro.redirect('/404');
const { title, featured_images, date, category_details, acf, gallery } =
  post.data;
console.log(gallery);
---

<PostLayout
  title={title.rendered}
  subtitle={title.rendered}
  bgImage={featured_images?.full?.url || ''}
>
  <article class="overflow-hidden bg-white py-2 sm:py-4">
    <div
      class="mx-auto bg-gray-100 rounded-lg p-2 sm:p-3 mb-3 flex items-center flex-wrap text-sm text-gray-500"
    >
      <ul class="flex items-center">
        <li class="inline-flex items-center">
          <a href="/" class="text-gray-600 hover:text-blue-500">
            <svg
              class="w-5 h-auto fill-current mx-1 text-gray-400"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="#000000"
              ><path d="M0 0h24v24H0V0z" fill="none"></path><path
                d="M10 19v-5h4v5c0 .55.45 1 1 1h3c.55 0 1-.45 1-1v-7h1.7c.46 0 .68-.57.33-.87L12.67 3.6c-.38-.34-.96-.34-1.34 0l-8.36 7.53c-.34.3-.13.87.33.87H5v7c0 .55.45 1 1 1h3c.55 0 1-.45 1-1z"
              ></path></svg
            >
          </a>

          <span class="mx-3 h-auto text-gray-400 font-medium">→</span>
        </li>

        <li class="inline-flex items-center">
          <a href="/catalogo" class="text-gray-600 hover:text-blue-500">
            Catálogo
          </a>

          <span class="mx-3 h-auto text-gray-400 font-medium">→</span>
        </li>

        <li class="inline-flex items-center">
          {
            category_details.map((cat) => (
              <a
                href={`/catalogo/categoria/${cat.slug}`}
                class="text-gray-600 hover:text-blue-500"
              >
                {cat.name}
              </a>
            ))
          }

          <span class="mx-3 h-auto text-gray-400 font-medium">→</span>
        </li>

        <li class="inline-flex items-center">
          {title.rendered.slice(0, 10) + '...'}
        </li>
      </ul>
    </div>
    <section>
      <div class="mx-auto max-w-7xl">
        <div
          class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-3 sm:gap-y-0 lg:mx-0 lg:max-w-none lg:grid-cols-2"
        >
          <div class="lg:pr-8 lg:pt-4">
            <div class="lg:max-w-lg">
              <PostMeta date={date} />

              <p
                class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl"
              >
                {title.rendered}
              </p>

              <div class="mt-3">
                {
                  category_details.map((cat) => (
                    <PostCategories name={cat.name} slug={cat.slug} />
                  ))
                }
              </div>

              <p class="mt-6 text-lg leading-8 text-gray-600">
                {acf.description}
              </p>
              <dl
                class="mt-5 max-w-xl space-y-8 text-base leading-7 text-gray-600 lg:max-w-none"
              >
                <!-- MARCA -->
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-gray-900">
                    <svg
                      aria-hidden="true"
                      focusable="false"
                      data-prefix="fas"
                      data-icon="tags"
                      class="svg-inline--fa fa-tags absolute left-1 top-1 h-5 w-5 text-coffee-900"
                      role="img"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 512 512"
                      ><path
                        fill="currentColor"
                        d="M345 39.1L472.8 168.4c52.4 53 52.4 138.2 0 191.2L360.8 472.9c-9.3 9.4-24.5 9.5-33.9 .2s-9.5-24.5-.2-33.9L438.6 325.9c33.9-34.3 33.9-89.4 0-123.7L310.9 72.9c-9.3-9.4-9.2-24.6 .2-33.9s24.6-9.2 33.9 .2zM0 229.5L0 80C0 53.5 21.5 32 48 32l149.5 0c17 0 33.3 6.7 45.3 18.7l168 168c25 25 25 65.5 0 90.5L277.3 442.7c-25 25-65.5 25-90.5 0l-168-168C6.7 262.7 0 246.5 0 229.5zM144 144a32 32 0 1 0 -64 0 32 32 0 1 0 64 0z"
                      ></path></svg
                    >
                  </dt>
                  <dd class="inline">
                    {acf.brand}
                  </dd>
                </div>
                <!-- LONGITUD -->
                {
                  acf.long ? (
                    <div class="relative pl-9">
                      <dt class="inline font-semibold text-gray-900">
                        <svg
                          aria-hidden="true"
                          focusable="false"
                          data-prefix="fas"
                          data-icon="ruler-vertical"
                          class="svg-inline--fa fa-ruler-vertical absolute left-1 top-1 h-5 w-5 text-coffee-900"
                          role="img"
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 256 512"
                        >
                          <path
                            fill="currentColor"
                            d="M0 48C0 21.5 21.5 0 48 0L208 0c26.5 0 48 21.5 48 48l0 48-80 0c-8.8 0-16 7.2-16 16s7.2 16 16 16l80 0 0 64-80 0c-8.8 0-16 7.2-16 16s7.2 16 16 16l80 0 0 64-80 0c-8.8 0-16 7.2-16 16s7.2 16 16 16l80 0 0 64-80 0c-8.8 0-16 7.2-16 16s7.2 16 16 16l80 0 0 48c0 26.5-21.5 48-48 48L48 512c-26.5 0-48-21.5-48-48L0 48z"
                          />
                        </svg>
                      </dt>
                      <dd class="inline">{acf.long}</dd>
                    </div>
                  ) : null
                }
                <!-- ANCHO -->
                {
                  acf.width ? (
                    <div class="relative pl-9">
                      <dt class="inline font-semibold text-gray-900">
                        <svg
                          aria-hidden="true"
                          focusable="false"
                          data-prefix="fas"
                          data-icon="ruler-horizontal"
                          class="svg-inline--fa fa-ruler-horizontal absolute left-1 top-1 h-5 w-5 text-coffee-900"
                          role="img"
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 640 512"
                        >
                          <path
                            fill="currentColor"
                            d="M0 336c0 26.5 21.5 48 48 48l544 0c26.5 0 48-21.5 48-48l0-160c0-26.5-21.5-48-48-48l-64 0 0 80c0 8.8-7.2 16-16 16s-16-7.2-16-16l0-80-64 0 0 80c0 8.8-7.2 16-16 16s-16-7.2-16-16l0-80-64 0 0 80c0 8.8-7.2 16-16 16s-16-7.2-16-16l0-80-64 0 0 80c0 8.8-7.2 16-16 16s-16-7.2-16-16l0-80-64 0 0 80c0 8.8-7.2 16-16 16s-16-7.2-16-16l0-80-64 0c-26.5 0-48 21.5-48 48L0 336z"
                          />
                        </svg>
                      </dt>
                      <dd class="inline">{acf.width}</dd>
                    </div>
                  ) : null
                }
                <!-- ESPESOR -->
                {
                  acf.thickness ? (
                    <div class="relative pl-9">
                      <dt class="inline font-semibold text-gray-900">
                        <svg
                          aria-hidden="true"
                          focusable="false"
                          data-prefix="fas"
                          data-icon="ruler-combined"
                          class="svg-inline--fa fa-ruler-combined absolute left-1 top-1 h-5 w-5 text-coffee-900 "
                          role="img"
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 512 512"
                        >
                          <path
                            fill="currentColor"
                            d="M.2 468.9C2.7 493.1 23.1 512 48 512l96 0 320 0c26.5 0 48-21.5 48-48l0-96c0-26.5-21.5-48-48-48l-48 0 0 80c0 8.8-7.2 16-16 16s-16-7.2-16-16l0-80-64 0 0 80c0 8.8-7.2 16-16 16s-16-7.2-16-16l0-80-64 0 0 80c0 8.8-7.2 16-16 16s-16-7.2-16-16l0-80-80 0c-8.8 0-16-7.2-16-16s7.2-16 16-16l80 0 0-64-80 0c-8.8 0-16-7.2-16-16s7.2-16 16-16l80 0 0-64-80 0c-8.8 0-16-7.2-16-16s7.2-16 16-16l80 0 0-48c0-26.5-21.5-48-48-48L48 0C21.5 0 0 21.5 0 48L0 368l0 96c0 1.7 .1 3.3 .2 4.9z"
                          />
                        </svg>
                      </dt>
                      <dd class="inline">{acf.thickness}</dd>
                    </div>
                  ) : null
                }
                <!-- CALIBRE -->
                {
                  acf.caliber ? (
                    <div class="relative pl-9">
                      <dt class="inline font-semibold text-gray-900">
                        <svg
                          aria-hidden="true"
                          focusable="false"
                          data-prefix="fas"
                          data-icon="arrows-down-to-line"
                          class="svg-inline--fa fa-arrows-down-to-line absolute left-1 top-1 h-5 w-5 text-coffee-900 "
                          role="img"
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 576 512"
                        >
                          <path
                            fill="currentColor"
                            d="M544 416L32 416c-17.7 0-32 14.3-32 32s14.3 32 32 32l512 0c17.7 0 32-14.3 32-32s-14.3-32-32-32zm22.6-137.4c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L480 274.7 480 64c0-17.7-14.3-32-32-32s-32 14.3-32 32l0 210.7-41.4-41.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l96 96c12.5 12.5 32.8 12.5 45.3 0l96-96zm-320-45.3c-12.5-12.5-32.8-12.5-45.3 0L160 274.7 160 64c0-17.7-14.3-32-32-32s-32 14.3-32 32l0 210.7L54.6 233.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l96 96c12.5 12.5 32.8 12.5 45.3 0l96-96c12.5-12.5 12.5-32.8 0-45.3z"
                          />
                        </svg>
                      </dt>
                      <dd class="inline">{acf.caliber}</dd>
                    </div>
                  ) : null
                }
                <!-- ENVIO -->

                <div class="relative pl-9">
                  <dt class="inline font-semibold text-gray-900">
                    <svg
                      aria-hidden="true"
                      focusable="false"
                      data-prefix="fas"
                      data-icon="truck-fast"
                      class="svg-inline--fa fa-truck-fast absolute left-1 top-1 h-5 w-5 text-coffee-900"
                      role="img"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 640 512"
                      ><path
                        fill="currentColor"
                        d="M112 0C85.5 0 64 21.5 64 48l0 48L16 96c-8.8 0-16 7.2-16 16s7.2 16 16 16l48 0 208 0c8.8 0 16 7.2 16 16s-7.2 16-16 16L64 160l-16 0c-8.8 0-16 7.2-16 16s7.2 16 16 16l16 0 176 0c8.8 0 16 7.2 16 16s-7.2 16-16 16L64 224l-48 0c-8.8 0-16 7.2-16 16s7.2 16 16 16l48 0 144 0c8.8 0 16 7.2 16 16s-7.2 16-16 16L64 288l0 128c0 53 43 96 96 96s96-43 96-96l128 0c0 53 43 96 96 96s96-43 96-96l32 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l0-64 0-32 0-18.7c0-17-6.7-33.3-18.7-45.3L512 114.7c-12-12-28.3-18.7-45.3-18.7L416 96l0-48c0-26.5-21.5-48-48-48L112 0zM544 237.3l0 18.7-128 0 0-96 50.7 0L544 237.3zM160 368a48 48 0 1 1 0 96 48 48 0 1 1 0-96zm272 48a48 48 0 1 1 96 0 48 48 0 1 1 -96 0z"
                      ></path></svg
                    >
                  </dt>
                  <dd class="inline">{acf.shipment}</dd>
                </div>
              </dl>
            </div>
            <div class="mt-10 flex flex-col md:flex-row items-center gap-x-6">
              {
                acf.navigation ? (
                  <a
                    href={acf.navigation}
                    class="rounded-md bg-coffee-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-coffee-500 focus-visible:outline  focus-visible:outline-offset-2 focus-visible:outline-coffee-600"
                  >
                    Ver en {acf.button_label}
                  </a>
                ) : null
              }
              <div class="relative pl-7 pr-3 mt-3 md:mt-0">
                <dt class="inline font-semibold text-gray-900">
                  <svg
                    aria-hidden="true"
                    focusable="false"
                    data-prefix="fas"
                    data-icon="phone"
                    class="svg-inline--fa fa-phone absolute left-2 top-2 h-3 w-3 text-coffee-900"
                    role="img"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 512 512"
                    ><path
                      fill="currentColor"
                      d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"
                    ></path></svg
                  >
                </dt>
                <dd class="inline">
                  <a
                    href="tel:+525582802149"
                    class="text-sm font-semibold leading-6 text-gray-700"
                    >Marcar Ahora
                    <span aria-hidden="true">→</span>
                  </a>
                </dd>
              </div>
            </div>
          </div>

          <div>
            <Picture
              src={featured_images?.medium_large?.url || ''}
              alt={title.rendered}
              width={featured_images?.medium_large?.width || 600}
              height={featured_images?.medium_large?.height || 400}
              formats={['avif', 'webp']}
              class="w-full lg:w-[48rem] h-full object-cover rounded-2xl"
            />
          </div>

          <div></div>

          <div id="gallery" class="grid grid-cols-1 lg:grid-cols-3 gap-5 mt-5">
            {
              gallery &&
                gallery.map((image) => (
                  <a
                    href={image.full.url}
                    data-pswp-width={image.full.width}
                    data-pswp-height={image.full.height}
                  >
                    <Picture
                      src={image?.large?.url || ''}
                      alt="Galería de imágenes"
                      width={image?.large?.width || 600}
                      height={image?.large?.height || 400}
                      formats={['avif', 'webp']}
                    />
                  </a>
                ))
            }
          </div>
        </div>
      </div>
    </section>
  </article>
</PostLayout>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
  });
  lightbox.init();
  document.addEventListener('astro:after-swap', function () {
    lightbox.init();
  });
</script>
