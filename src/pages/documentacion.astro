---
import PostLayout from "@/layouts/PostLayout.astro";
import BlogPosts from "@/components/documentacion/BlogPosts.astro";
import { BaseWPSchema } from "@/types";
const url = `${import.meta.env.API_URL}/pages?slug=documentacion`;
const response = await fetch(url);
const json = await response.json();
const data = BaseWPSchema.parse(json[0]);
console.log(data);
---

<PostLayout
  title="Blog"
  subtitle="Documentación"
  bgImage={data.featured_images.full.url}
>
  <div
    class="text-xl space-y-3 mt-10 lg:mt-0"
    set:html={data.content.rendered}
  />

  <BlogPosts />
</PostLayout>
