---
import PostLayout from "@/layouts/PostLayout.astro";
import BlogPosts from "@/components/documentacion/BlogPosts.astro";
import PostCategories from "@/components/ui/PostCategories.astro";
import { BaseWPSchema } from "@/types";
const url = `${import.meta.env.API_URL}/pages?slug=documentacion`;
const response = await fetch(url);
const json = await response.json();
const data = BaseWPSchema.parse(json[0]);
console.log(data);
---

<PostLayout
  title="Documentación"
  subtitle="Documentación"
  bgImage={data?.featured_images?.full?.url || ""}
>
  <div
    class="text-lg sm:text-xl space-y-3 mt-2 sm:mt-10 lg:mt-0 line-clamp-5 md:line-clamp-none"
    set:html={data.content.rendered}
  />
  <PostCategories />
  <BlogPosts />
</PostLayout>
