---
import Layout from '@/layouts/Layout.astro';
import ProductsPosts from '@/components/products/ProductsPosts.astro';
import ProductCategories from '@/components/ui/ProductCategories.astro';
import { BaseWPSchema } from '@/types';
const url = `${import.meta.env.API_URL}/pages?slug=catalogo`;
const response = await fetch(url);
const json = await response.json();
const data = BaseWPSchema.parse(json[0]);
// console.log(data);
---

<Layout
  title="Catálogo"
  subtitle={data?.acf?.subtitle || 'Nuestro catálogo de productos'}
  bgImage={data?.featured_images?.full?.url || ''}
>
  <div
    class="text-lg sm:text-xl space-y-3 mt-2 sm:mt-10 lg:mt-0 line-clamp-5 md:line-clamp-none"
    set:html={data.content.rendered}
  />

  <ProductCategories />
  <ProductsPosts />
</Layout>
