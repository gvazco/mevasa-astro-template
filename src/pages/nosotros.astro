---
import Layout from '@/layouts/Layout.astro';
import AboutGallery from '@/components/gallery/AboutGallery.astro';
import { Picture } from 'astro:assets';
import { BaseWPSchema } from '@/types';
const url = `${import.meta.env.API_URL}/pages?slug=nosotros`;
const response = await fetch(url);
const json = await response.json();
const data = BaseWPSchema.parse(json[0]);
// console.log(data);
---

<Layout
  title="Nosotros"
  subtitle={data?.acf?.subtitle || ''}
  bgImage={data?.featured_images?.full?.url || ''}
>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
    <div id="gallery">
      <a
        href={data?.featured_images?.full.url}
        data-pswp-width={data?.featured_images?.full.width}
        data-pswp-height={data?.featured_images?.full.height}
      >
        <Picture
          src={data?.featured_images?.medium_large?.url || ''}
          alt={data?.title.rendered}
          width={data?.featured_images?.medium_large?.width || 600}
          height={data?.featured_images?.medium_large?.height || 600}
          formats={['avif', 'webp']}
        />
      </a>
      <AboutGallery />
    </div>

    <div
      class="text-xl space-y-3 mt-10 lg:mt-0"
      set:html={data?.content?.rendered}
    />
  </div>
</Layout>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
  });
  lightbox.init();
  document.addEventListener('astro:after-swap', function () {
    lightbox.init();
  });
</script>
