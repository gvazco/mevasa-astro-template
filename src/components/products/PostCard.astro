---
import { Picture } from 'astro:assets';
import type { Product } from '@/types';
import PostMeta from './PostMeta.astro';
import PostCategories from './PostCategories.astro';
interface Props {
  post: Product;
}
const { post } = Astro.props;
// console.log(post);
---

<article
  class="overflow-hidden bg-white py-6 mt-2 border-b last-of-type:border-0 border-zinc-300"
>
  <div class="mx-auto max-w-7xl">
    <div
      class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-8 md:gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2"
    >
      {
        post?.featured_images?.medium_large?.url && (
          <Picture
            src={post.featured_images.medium_large.url}
            alt={post?.title.rendered}
            width={post?.featured_images?.medium_large?.width || 600}
            height={post?.featured_images?.medium_large?.height || 600}
            formats={['avif', 'webp']}
            class="w-full lg:w-[30rem] h-full lg:h-[30rem] object-cover rounded-2xl"
          />
        )
      }
      <div class="lg:pr-8 lg:pt-4">
        <div class="lg:max-w-lg">
          <PostMeta date={post.date} />

          <h3 class="text-gray-900 font-black text-2xl sm:text-4xl uppercase">
            <a href={`/catalogo/${post.slug}`}>
              {post.title.rendered}
            </a>
          </h3>

          <div class="mt-3">
            {
              post.category_details.map((cat) => (
                <PostCategories name={cat.name} slug={cat.slug} />
              ))
            }
          </div>
          <dl
            class="mt-10 max-w-xl space-y-8 text-base leading-7 text-gray-600 lg:max-w-none"
          >
            <div class="relative pl-9">
              <svg
                aria-hidden="true"
                focusable="false"
                data-prefix="fas"
                data-icon="circle-info"
                class="svg-inline--fa fa-circle-info absolute left-1 top-1 h-5 w-5 text-yellow-900"
                role="img"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 512 512"
                ><path
                  fill="currentColor"
                  d="M256 512A256 256 0 1 0 256 0a256 256 0 1 0 0 512zM216 336l24 0 0-64-24 0c-13.3 0-24-10.7-24-24s10.7-24 24-24l48 0c13.3 0 24 10.7 24 24l0 88 8 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-80 0c-13.3 0-24-10.7-24-24s10.7-24 24-24zm40-208a32 32 0 1 1 0 64 32 32 0 1 1 0-64z"
                ></path></svg
              >

              <dd class="line-clamp-2 md:line-clamp-none" id="summary">
                {post.acf.summary}
              </dd>
            </div>
          </dl>
        </div>
        <div class="mt-10 flex items-center gap-x-6">
          {
            post.acf.navigation ? (
              <a
                href={post.acf.navigation}
                class="rounded-md bg-yellow-700 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-yellow-600 focus-visible:outline  focus-visible:outline-offset-2 focus-visible:outline-yellow-700"
              >
                Ver en {post.acf.button_label}
              </a>
            ) : null
          }

          <a
            href={`/catalogo/${post.slug}`}
            class="text-sm font-semibold leading-6 text-gray-700"
            >Ver ficha completa <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</article>
