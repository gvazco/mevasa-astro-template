---
import Logo from '@/assets/logo.svg';
import MainNav from './MainNav.astro';

interface Props {
  bgImage: string;
  title: string;
}

const { bgImage, title } = Astro.props;
---

<header class="min-h-36 relative md:pb-36">
  <div
    class="absolute inset-0 bg-center bg-cover bg-image"
    style={{ backgroundImage: `url(${bgImage})` }}
  >
  </div>
  <div class="absolute inset-0 bg-black/60"></div>

  <div class="relative max-w-7xl mx-auto py-10 md:py-14 px-4 md:px-0">
    <div class="flex flex-col md:flex-row md:justify-between">
      <a href="/" class="mx-auto md:mx-0">
        <Logo class="w-32 md:w-72" />
      </a>
      <div id="nav-menu" class="md:flex md:flex-row md:gap-3">
        <MainNav />
      </div>
    </div>

    <h1
      class="text-2xl md:text-4xl font-black uppercase text-white text-center mt-8 md:mt-20 lg:mt-32 after:coffee-icon"
    >
      {title}
    </h1>
  </div>
</header>
