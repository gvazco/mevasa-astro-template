---
import Logo from "@/assets/logo.svg";
import MainNav from "./MainNav.astro";

interface Props {
  bgImage: string;
  subtitle: string;
}

const { bgImage, subtitle } = Astro.props;
---

<header class="min-h-72 relative md:pb-72">
  <div
    class="absolute inset-0 bg-center bg-cover bg-image"
    style={{ backgroundImage: `url(${bgImage})` }}
  >
  </div>
  <div class="absolute inset-0 bg-black/60"></div>

  <div class="relative max-w-7xl mx-auto py-10 md:py-14 px-4 md:px-0">
    <div class="flex flex-col md:flex-row md:justify-between">
      <a href="/" class="mx-auto md:mx-0">
        <Logo class="w-32 md:w-72" />
      </a>
      <!-- Botón hamburguesa para móviles -->
      <button
        id="menu-toggle"
        class="md:hidden text-white text-3xl focus:outline-none"
        aria-label="Toggle menu"
      >
        ☰
      </button>
      <!-- Navegación -->
      <div id="nav-menu" class="hidden md:flex md:flex-row md:gap-3">
        <MainNav />
      </div>
    </div>

    <h1
      class="text-2xl md:text-4xl font-black uppercase text-white text-center mt-8 md:mt-20 lg:mt-32"
    >
      {subtitle}
    </h1>
  </div>
</header>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const navMenu = document.getElementById("nav-menu");

  if (menuToggle && navMenu) {
    menuToggle.addEventListener("click", () => {
      navMenu.classList.toggle("hidden");
    });
  }
</script>
