---
import { ClientRouter, fade, slide } from 'astro:transitions';
import '@/styles/global.css';
import PostHeader from '@/components/ui/PostHeader.astro';
import Footer from '@/components/ui/Footer.astro';

interface Props {
  title: string;
  bgImage: string;
}

const { title, bgImage } = Astro.props;
const description =
  'Mevasa Comercializadora se especializa en la venta de lámina de acero, accesorios de fijación, montaje, sellos, aislantes, molduras, herramientas y productos ferreteros. Gracias a nuestra experiencia y compromiso, hemos logrado llevar soluciones a clientes en toda la República Mexicana.';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Mevasa Comercializadora</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/fijacion.webp" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&family=PT+Sans:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>

  <body class="bg-coffee-100">
    <PostHeader
      title={title}
      bgImage={bgImage}
      transition:animate={fade({ duration: '.5s' })}
    />

    <main
      class="bg-white p-5 sm:p-8 md:p-10 max-w-7xl mx-auto lg:-mt-20 relative"
    >
      <div transition:animate={slide({ duration: '1s' })}>
        <slot />
      </div>
    </main>

    <slot name="after-main-content" />

    <Footer />
  </body>
</html>
